[user]
  email = polleninjp@gmail.com
  name = pollenjp

[gpg]
  format = ssh

[gpg "ssh"]
  defaultKeyCommand = sh -c 'echo key::$(ssh-add -L | grep "Signing" | awk NR=1)'

  ## DON'T COMMIT WITH UNCOMMENT
  ## https://developer.1password.com/docs/ssh/integrations/wsl/#sign-git-commits-with-ssh
  #
  ## Only for WSL
  # program = "/mnt/c/Users/polle/AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"
  ## Windows Host
  # program = "C:/Users/polle/AppData/Local/Microsoft/WindowsApps/op-ssh-sign.exe"

[commit]
  gpgsign = true

[includeIf "gitdir:~/workdir/github.com/pollenjp-sub"]
  path = ~/dotfiles/.gitconfig.pollenjp-sub.github.com

[core]
  editor = vim
  quotepath = false
  autocrlf = false

  # for git-delta
  pager = delta

[pager]
  branch = false
[push]
  default = simple
[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  w  = switch
  push-f = push --force-with-lease
[init]
  defaultBranch = main

[interactive]
  diffFilter = delta --color-only

[delta]
  # for git-delta
  navigate = true

[merge]
  # for git-delta
  conflictstyle = diff3

[diff]
  # for git-delta
  colorMoved = default
[pull]
  rebase = false

[filter "lfs"]
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
